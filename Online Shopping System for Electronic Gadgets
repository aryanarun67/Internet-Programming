
<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>TechSavvy Electronics Store</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{

background:
linear-gradient(
rgba(0,0,0,.65),
rgba(0,0,0,.65)
),

url("https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=1800");

background-size:cover;
background-position:center;
background-attachment:fixed;

color:white;
}

/* NAVBAR */

nav{

display:flex;
justify-content:space-between;
align-items:center;

padding:20px 60px;

background:rgba(0,0,0,.25);

backdrop-filter:blur(12px);

position:sticky;
top:0;
z-index:1000;
}

.logo{

font-size:34px;
font-weight:bold;

color:#00E5FF;
}

nav ul{

display:flex;
gap:30px;
list-style:none;
}

nav ul li{

cursor:pointer;
transition:.3s;
}

nav ul li:hover{

color:#00E5FF;
}

.btn{

padding:12px 25px;

border:none;

border-radius:30px;

font-weight:bold;

cursor:pointer;

background:
linear-gradient(
45deg,
#00E5FF,
#4FC3F7
);

color:black;
}

/* HERO */

.hero{

height:90vh;

display:flex;
flex-direction:column;

justify-content:center;
align-items:center;

text-align:center;

padding:20px;
}

.hero h1{

font-size:80px;

margin-bottom:20px;

background:
linear-gradient(
90deg,
#ffffff,
#00E5FF,
#ffffff
);

-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

.hero p{

font-size:22px;

max-width:900px;

color:#dffbff;
}

/* SEARCH */

.search-box{

margin-top:35px;

background:rgba(255,255,255,.12);

backdrop-filter:blur(12px);

padding:25px;

border-radius:20px;
}

.search-box input,
.search-box select{

padding:12px;

margin:10px;

border:none;

border-radius:10px;

width:220px;
}

/* STATS */

.stats{

display:flex;

justify-content:center;

flex-wrap:wrap;

gap:25px;

padding:50px;
}

.stat-card{

width:220px;

padding:25px;

text-align:center;

background:rgba(255,255,255,.12);

backdrop-filter:blur(10px);

border-radius:20px;
}

.stat-card h2{

color:#00E5FF;
}

/* TITLE */

.section-title{

text-align:center;

font-size:40px;

color:#00E5FF;

margin:50px 0;
}

/* PRODUCT CARDS */

.container{

display:flex;

justify-content:center;

flex-wrap:wrap;

gap:30px;

padding:20px 40px 60px;
}

.card{

width:300px;

background:rgba(255,255,255,.12);

backdrop-filter:blur(15px);

border-radius:20px;

overflow:hidden;

transition:.4s;
}

.card:hover{

transform:translateY(-10px);

box-shadow:
0 15px 35px rgba(0,229,255,.3);
}

.card img{

width:100%;
height:220px;

object-fit:cover;
}

.card-content{

padding:20px;
}

.card-content h3{

color:#00E5FF;

margin-bottom:10px;
}

.card-content p{

line-height:1.6;
}

.price{

font-size:22px;

font-weight:bold;

margin-top:10px;

color:#4FC3F7;
}

/* CATEGORY BOXES */

.categories{

display:flex;

justify-content:center;

flex-wrap:wrap;

gap:20px;

padding:30px;
}

.category{

padding:18px 30px;

background:rgba(255,255,255,.12);

backdrop-filter:blur(10px);

border-radius:15px;
}

/* FOOTER */

footer{

text-align:center;

padding:25px;

background:rgba(0,0,0,.4);
}

</style>

</head>

<body>

<nav>

<div class="logo">💻 TechSavvy</div>

