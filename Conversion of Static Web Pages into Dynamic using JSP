index.jsp

<%@ page language="java" contentType="text/html; charset=UTF-8"
pageEncoding="UTF-8"%>

<!DOCTYPE html>

<html>

<head>

<title>Student Portal JSP</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{

background:
linear-gradient(
rgba(0,0,0,.65),
rgba(0,0,0,.65)
),

url("https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=1800");

background-size:cover;
background-position:center;

height:100vh;

display:flex;
justify-content:center;
align-items:center;
}

.container{

width:500px;

padding:30px;

background:rgba(255,255,255,.12);

backdrop-filter:blur(12px);

border-radius:20px;

color:white;
}

h1{

text-align:center;

color:#00E5FF;

margin-bottom:20px;
}

input{

width:100%;

padding:12px;

margin:10px 0;

border:none;

border-radius:10px;
}

button{

width:100%;

padding:12px;

border:none;

border-radius:10px;

background:#00E5FF;

font-weight:bold;

cursor:pointer;
}

</style>

</head>

<body>

<div class="container">

<h1>Student Portal</h1>

<form action="welcome.jsp" method="post">

<input type="text"
name="studentName"
placeholder="Enter Student Name"
required>

<input type="text"
name="department"
placeholder="Enter Department"
required>

<button type="submit">

Submit

</button>

</form>

</div>

</body>

</html>

welcome.jsp

<%@ page language="java" contentType="text/html; charset=UTF-8"
pageEncoding="UTF-8"%>

<%
String name = request.getParameter("studentName");
String department = request.getParameter("department");
%>

<!DOCTYPE html>

<html>

<head>

<title>Welcome Page</title>

<style>

body{

font-family:Arial;

background:#f4f4f4;

padding:50px;
}

.box{

width:600px;

margin:auto;

padding:30px;

background:white;

border-radius:15px;

box-shadow:0 0 15px rgba(0,0,0,.2);
}

h1{

color:#007BFF;
}

p{

font-size:20px;
}

</style>

</head>

<body>

<div class="box">

<h1>Student Information</h1>

<p><b>Name:</b> <%= name %></p>

<p><b>Department:</b> <%= department %></p>

<p><b>Current Date & Time:</b>

<%= new java.util.Date() %>

</p>

</div>

</body>

</html>
