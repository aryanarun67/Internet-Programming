import java.io.*;
import javax.servlet.*;
import javax.servlet.http.*;

public class OnlineExamServlet extends HttpServlet {

    public void doGet(HttpServletRequest request,
                      HttpServletResponse response)
                      throws IOException, ServletException {

        response.setContentType("text/html");

        PrintWriter out = response.getWriter();

        out.println("<html>");
        out.println("<head>");

        out.println("<title>Online Examination System</title>");

        out.println("<style>");

        out.println("body{font-family:Segoe UI;background:#f4f4f4;padding:30px;}");

        out.println(".container{width:800px;margin:auto;background:white;padding:30px;border-radius:15px;box-shadow:0 0 15px rgba(0,0,0,.2);}");

        out.println("h1{color:#007BFF;text-align:center;}");

        out.println("button{padding:12px 25px;background:#007BFF;color:white;border:none;border-radius:8px;cursor:pointer;}");

        out.println("</style>");

        out.println("</head>");
        out.println("<body>");

        out.println("<div class='container'>");

        out.println("<h1>Online Examination</h1>");

        out.println("<form method='post'>");

        out.println("<p><b>1. Java is a _____ language.</b></p>");
        out.println("<input type='radio' name='q1' value='Object Oriented'> Object Oriented<br>");
        out.println("<input type='radio' name='q1' value='Procedural'> Procedural<br><br>");

        out.println("<p><b>2. HTML stands for?</b></p>");
        out.println("<input type='radio' name='q2' value='HyperText Markup Language'> HyperText Markup Language<br>");
        out.println("<input type='radio' name='q2' value='HighText Machine Language'> HighText Machine Language<br><br>");

        out.println("<p><b>3. Which is a Database?</b></p>");
        out.println("<input type='radio' name='q3' value='MySQL'> MySQL<br>");
        out.println("<input type='radio' name='q3' value='Java'> Java<br><br>");

        out.println("<button type='submit'>Submit Exam</button>");

        out.println("</form>");

        out.println("</div>");

        out.println("</body>");
        out.println("</html>");
    }

    public void doPost(HttpServletRequest request,
                       HttpServletResponse response)
                       throws IOException, ServletException {

        response.setContentType("text/html");

        PrintWriter out = response.getWriter();

        int score = 0;

        if("Object Oriented".equals(request.getParameter("q1")))
            score++;

        if("HyperText Markup Language".equals(request.getParameter("q2")))
            score++;

        if("MySQL".equals(request.getParameter("q3")))
            score++;

        out.println("<html>");
        out.println("<head>");

        out.println("<style>");

        out.println("body{font-family:Segoe UI;background:#f4f4f4;padding:50px;}");

        out.println(".result{width:500px;margin:auto;background:white;padding:30px;border-radius:15px;text-align:center;box-shadow:0 0 15px rgba(0,0,0,.2);}");

        out.println("h1{color:green;}");

        out.println("</style>");

        out.println("</head>");

        out.println("<body>");

        out.println("<div class='result'>");

        out.println("<h1>Exam Result</h1>");

        out.println("<h2>Your Score: " + score + " / 3</h2>");

        if(score >= 2)
            out.println("<h3 style='color:green'>PASS</h3>");
        else
            out.println("<h3 style='color:red'>FAIL</h3>");

        out.println("</div>");

        out.println("</body>");
        out.println("</html>");
    }
}
